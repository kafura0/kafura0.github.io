6 max-w-3xl mx-auto"><div><div class="text-3xl lg:text-4xl font-bold text-foreground">42+</div><div class="mt-1 text-sm text-muted-foreground">Years in business</div></div><div><div class="text-3xl lg:text-4xl font-bold text-foreground">5</div><div class="mt-1 text-sm text-muted-foreground">Service lines</div></div><div><div class="text-3xl lg:text-4xl font-bold text-foreground">3</div><div class="mt-1 text-sm text-muted-foreground">In-house products</div></div><div><div class="text-3xl lg:text-4xl font-bold text-foreground">100%</div><div class="mt-1 text-sm text-muted-foreground">Delivered in-house</div></div></div></div></section><div hidden><h2>Main sections</h2>
