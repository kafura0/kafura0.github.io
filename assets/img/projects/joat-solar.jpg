<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JOAT Kenya | Software, Digital Marketing, Media & AI Studio</title>
    <meta
      name="description"
      content="JOAT Kenya is a digital innovation studio. We build software, run AI marketing, produce media and launch in-house products (BioBiz, Majobo) worldwide."
    />
    <meta
      name="keywords"
      content="JOAT Kenya, J.O.A.T. Kenya, digital innovation studio, software development, mobile app development, web development, digital marketing, AI solutions, media production, animation studio, children's digital education, BioBiz, Majobo Kenya"
    />
    <meta name="author" content="JOAT KENYA" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f7f5f0" />
    <link rel="canonical" href="https://joatkenya.com/" />
    <link rel="icon" type="image/png" href="/joat-logo.png" />
    <link rel="apple-touch-icon" href="/joat-logo.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- OpenSearch descriptor — lets Chrome / Firefox / Edge / Brave offer
         joatkenya.com as a search engine the user can add to the URL bar. -->
    <link rel="search" type="application/opensearchdescription+xml" title="JOAT Kenya" href="/opensearch.xml" />

    <!-- Webmaster verification slots. Each one is dormant until you paste the
         token from that engine's webmaster console. Once added, the site is
         claimed and your sitemap is accepted there.

         How to claim each (one-time setup, ~5 min per engine):
           Bing  Webmaster Tools  →  https://www.bing.com/webmasters     (covers ChatGPT Search, Perplexity, You.com, DuckDuckGo, Copilot)
           Yandex Webmaster       →  https://webmaster.yandex.com         (covers Russia, CIS, Turkey, parts of Eastern Europe)
           Naver Search Advisor   →  https://searchadvisor.naver.com      (covers South Korea)
           Baidu Webmaster        →  https://ziyuan.baidu.com             (covers Mainland China — only if targeting)

         Replace the placeholder content="" once you have each token. -->
    <meta name="msvalidate.01" content="" />
    <meta name="yandex-verification" content="" />
    <meta name="naver-site-verification" content="" />
    <meta name="google-site-verification" content="" />

    <!-- Open Graph -->
    <meta property="og:title" content="JOAT Kenya | Software, Digital Marketing, Media & AI Studio" />
    <meta
      property="og:description"
      content="JOAT Kenya is a digital innovation studio. We build software, run AI marketing, produce media and launch in-house products (BioBiz, Majobo) worldwide."
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="J.O.A.T. Kenya" />
    <meta property="og:url" content="https://joatkenya.com/" />
    <meta property="og:image" content="https://joatkenya.com/joat-logo.png" />
    <meta property="og:locale" content="en_KE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="JOAT Kenya | Software, Digital Marketing, Media & AI Studio" />
    <meta
      name="twitter:description"
      content="JOAT Kenya is a digital innovation studio. We build software, run AI marketing, produce media and launch in-house products (BioBiz, Majobo) worldwide."
    />
    <meta name="twitter:image" content="https://joatkenya.com/joat-logo.png" />

    <!-- Preload the logo (LCP candidate above the fold) and warm font origin
         connections so the fetches start in parallel with HTML parsing. -->
    <link rel="preload" as="image" href="/joat-logo.png" fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Non-blocking Google Fonts via the print-swap trick: fetched as a
         low-priority stylesheet (media="print") and promoted to media="all"
         once loaded. Result: the stylesheet doesn't block first paint. -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700;800&display=swap"
      />
    </noscript>

    <!-- Analytics & heatmaps deferred to the `load` event — they no longer
         compete with the critical render path. GA4 (G-XBWFZR7M3V) and
         Microsoft Clarity (x18d98fzqg) still fire automatically for SPA route
         changes; only their initial load is delayed.

         The shim below buffers any gtag()/clarity() calls that fire BEFORE
         the real scripts are loaded so no events are lost during the window
         between first paint and the deferred load. -->
    <script>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function(){ dataLayer.push(arguments); };
      gtag('js', new Date());
      gtag('config', 'G-XBWFZR7M3V', { anonymize_ip: true });
      window.clarity = window.clarity || function(){ (clarity.q = clarity.q || []).push(arguments); };

      function loadAnalytics() {
        // GA4 gtag.js
        var ga = document.createElement('script');
        ga.async = true;
        ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-XBWFZR7M3V';
        document.head.appendChild(ga);

        // Microsoft Clarity
        var cl = document.createElement('script');
        cl.async = true;
        cl.src = 'https://www.clarity.ms/tag/x18d98fzqg';
        document.head.appendChild(cl);
      }

      if (document.readyState === 'complete') {
        setTimeout(loadAnalytics, 1500);
      } else {
        window.addEventListener('load', function () { setTimeout(loadAnalytics, 1500); });
      }
    </script>
    <script type="module" crossorigin src="/assets/index-JVRvTr-x.js"></script>
